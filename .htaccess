# GoToolly - Clean URLs
# 1) Redirect legacy /pages/*.html to clean URLs (301 permanent)
# 2) Redirect any requests for *.html at root to clean URL (optional)
# 3) Internally rewrite clean URLs to their .html files when they exist
# 4) Exclude static assets from rewrites

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # --- Redirect /pages/foo.html -> /foo (preserve nested paths) ---
  # Use THE_REQUEST to avoid redirect loops and preserve query strings
  RewriteCond %{THE_REQUEST} \s/pages/([^
\s]+)\.html[?\s] [NC]
  RewriteRule ^pages/(.+)\.html$ /$1 [R=301,L]

  # --- Redirect any /something.html -> /something (optional, helpful for moved files) ---
  RewriteCond %{THE_REQUEST} \s/([^.\s]+)\.html[?\s] [NC]
  RewriteRule ^([^.]+)\.html$ /$1 [R=301,L]

  # --- Do not touch requests for static assets ---
  RewriteCond %{REQUEST_URI} \.(css|js|png|jpg|jpeg|gif|svg|webp|woff2|woff|ttf|ico)$ [NC]
  RewriteRule .* - [L]

  # --- Internally rewrite clean URLs to existing .html files ---
  # If the requested path is not a file or directory and a .html exists, serve it from the filesystem.
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{DOCUMENT_ROOT}/pages/%{REQUEST_URI}.html -f
  RewriteRule ^(.*)$ /pages/$1.html [L]

  # Fallback: if a matching .html next to the requested path exists (e.g., /tools/foo -> /tools/foo.html)
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.*?)/?$ $1.html [L]

</IfModule>

# Helpful headers
<IfModule mod_headers.c>
  <FilesMatch "\.(html|htm)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>
